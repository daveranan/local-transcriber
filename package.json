{
  "name": "livescriber",
  "version": "0.1.8",
  "private": true,
  "author": "daveranan",
  "description": "Local desktop and microphone transcription.",
  "repository": {
    "type": "git",
    "url": "https://github.com/daveranan/local-transcriber.git"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc --noEmit && vite build",
    "build:test": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-and-test.ps1",
    "dist": "npm run build && electron-builder --publish never",
    "publish": "npm run build && electron-builder --publish always",
    "start": "electron ."
  },
  "build": {
    "appId": "com.daveranan.livescriber",
    "productName": "Livescriber",
    "directories": {
      "output": "release"
    },
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "daveranan",
        "repo": "local-transcriber",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "lucide-react": "^0.468.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "wait-on": "^9.0.3"
  }
}
